---
import Layout from "../layouts/Layout.astro";
import { Wine, Disc3, Coffee } from "@lucide/astro";
// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <div
    class="relative flex min-h-screen w-full flex-col items-center justify-center overflow-x-hidden p-6"
  >
    <main
      class="layout-container flex h-full grow flex-col items-center justify-center max-w-4xl w-full"
    >
      <div class="flex flex-col items-center text-center space-y-12 w-full">
        <!-- Brand Identity -->
        <div class="space-y-4">
          <h1
            class="text-black tracking-[0.2em] text-6xl md:text-8xl font-bold uppercase leading-none"
          >
            LA ROTONDE
          </h1>
          <h2
            class="font-serif italic text-xl md:text-2xl text-black/80 font-medium"
          >
            Opening Soon in Hillcrest, San Diego
          </h2>
        </div>
        <div class="flex flex-col">
          <p class="font-mono text-[10px] uppercase tracking-widest">
            Coffee &mdash; Music &mdash; Wine
          </p>
        </div>
        <!-- Minimalist Iconography -->
        <div class="flex gap-8 py-4">
          <Coffee class="text-4xl text-black" />
          <Disc3 class="text-4xl text-black" />
          <Wine class="text-4xl text-black" />
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-12 text-center">
      <p class="font-mono text-[10px] text-black/40 mt-4">
        © 2026 Rotunde. All rights reserved.
      </p>
    </footer>
  </div>
</Layout>

<style is:global>
  h1 {
    font-family: "Space Grotesk Variable", sans-serif;
  }
  h2 {
    font-family: "Playfair Display Variable", serif;
  }
</style>
